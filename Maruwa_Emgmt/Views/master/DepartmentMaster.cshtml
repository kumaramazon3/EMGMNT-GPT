@{
    ViewData["Title"] = "Department Master";
}

<div class="container-fluid mt-3">
    @Html.AntiForgeryToken()
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <span>Department Master</span>
            <button type="button" class="btn btn-light btn-sm" onclick="openDepartmentModal()"><i class="bi bi-plus-circle"></i> Add Department</button>
        </div>
        <div class="card-body">
            <div class="row mb-2 align-items-center">
                <div class="col-md-2">
                    <select id="pageSizeSelect" class="form-control form-control-sm">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
                <div class="col-md-7">
                    <input type="text" id="globalSearch" class="form-control form-control-sm" placeholder="Global search across all columns" />
                </div>
                <div class="col-md-3 text-right">
                    <button class="btn btn-success btn-sm" onclick="exportDepartment('xlsx')">Excel</button>
                    <button class="btn btn-info btn-sm" onclick="exportDepartment('csv')">CSV</button>
                    <button class="btn btn-danger btn-sm" onclick="exportDepartment('pdf')">PDF</button>
                    <button class="btn btn-secondary btn-sm" onclick="window.print()">Print</button>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-sm" id="tblDepartment" style="font-size:13px;">
                    <thead class="bg-secondary text-white">
                        <tr>
                            <th>Edit</th>
                            <th>Delete</th>
                            <th data-sort="DepartmentCode">Department Code</th>
                            <th data-sort="DepartmentName">Department Name</th>
                            <th data-sort="JapanHead">Japan Head</th>
                            <th data-sort="Office">Office</th>
                            <th data-sort="GotSection">Got Section</th>
                            <th data-sort="Prefix">Prefix</th>
                            <th data-sort="CreatedBy">Created By</th>
                            <th data-sort="CreatedOn">Created On</th>
                            <th data-sort="EditedBy">Edited By</th>
                            <th data-sort="EditedOn">Edited On</th>
                            <th data-sort="ActiveStatus">Active Status</th>
                        </tr>
                        <tr class="bg-light text-dark">
                            <th></th><th></th>
                            <th><input class="form-control form-control-sm column-search" data-field="departmentCode" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="departmentName" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="japanHead" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="office" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="gotSection" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="prefix" /></th>
                            <th colspan="5"></th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
            <div class="d-flex justify-content-between align-items-center">
                <span id="recordInfo"></span>
                <div>
                    <button class="btn btn-outline-secondary btn-sm" id="btnPrev">Prev</button>
                    <span id="pageInfo" class="mx-2"></span>
                    <button class="btn btn-outline-secondary btn-sm" id="btnNext">Next</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="departmentModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="departmentModalTitle">Add Department</h5>
                <button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <form id="departmentForm">
                    <input type="hidden" id="recordNo" name="RecordNo" value="0" />
                    <div class="row">
                        <div class="col-md-6 form-group"><label>Department Code</label><input class="form-control" id="departmentCode" name="DepartmentCode" required maxlength="20" /></div>
                        <div class="col-md-6 form-group"><label>Department Name</label><input class="form-control" id="departmentName" name="DepartmentName" required maxlength="150" /></div>
                        <div class="col-md-4 form-group"><label>Get Japanese Head</label><select class="form-control" id="japanHead" name="JapanHead" required><option value="">--Select--</option><option>Yes</option><option>No</option></select></div>
                        <div class="col-md-4 form-group"><label>Got Section</label><select class="form-control" id="gotSection" name="GotSection" required><option value="">--Select--</option><option>Yes</option><option>No</option></select></div>
                        <div class="col-md-4 form-group"><label>Direct/Indirect Dept</label><select class="form-control" id="office" name="Office" required><option value="">--Select--</option><option>Direct</option><option>Indirect</option></select></div>
                        <div class="col-md-6 form-group"><label>General Abbreviation</label><input class="form-control" id="prefix" name="Prefix" required maxlength="20" /></div>
                    </div>
                </form>
                <div class="alert d-none" id="formMessage"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Exit</button>
                <button type="button" class="btn btn-primary" onclick="saveDepartment()">Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteDepartmentModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white"><h5 class="modal-title">Confirm Delete</h5><button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button></div>
            <div class="modal-body">Are you sure you want to delete this department?</div>
            <div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button><button type="button" class="btn btn-danger" id="btnConfirmDepartmentDelete">Delete</button></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/master/jsDepartmentMaster.js"></script>
}
