@{
    ViewData["Title"] = "Designation Master";
}

<div class="container-fluid mt-3">
    @Html.AntiForgeryToken()
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <span>Designation Master</span>
            <button type="button" class="btn btn-light btn-sm" onclick="openDesignationModal()"><i class="bi bi-plus-circle"></i> Add Designation</button>
        </div>
        <div class="card-body">
            <div class="row mb-2 align-items-center">
                <div class="col-md-2">
                    <select id="pageSizeSelect" class="form-control form-control-sm">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
                <div class="col-md-7">
                    <input type="text" id="globalSearch" class="form-control form-control-sm" placeholder="Global search across all designation columns" />
                </div>
                <div class="col-md-3 text-right">
                    <button class="btn btn-success btn-sm" onclick="exportDesignation('xlsx')">Excel</button>
                    <button class="btn btn-info btn-sm" onclick="exportDesignation('csv')">CSV</button>
                    <button class="btn btn-danger btn-sm" onclick="exportDesignation('pdf')">PDF</button>
                    <button class="btn btn-secondary btn-sm" onclick="window.print()">Print</button>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-sm" id="tblDesignation" style="font-size:13px;">
                    <thead class="bg-secondary text-white">
                        <tr>
                            <th>Edit</th>
                            <th>Delete</th>
                            <th data-sort="designationcode">designationcode</th>
                            <th data-sort="designationName">designationName</th>
                            <th data-sort="probation">probation</th>
                            <th data-sort="insCatergory">insurance Catergory</th>
                            <th data-sort="insamount">insurance amount</th>
                            <th data-sort="CreatedBy">Created By</th>
                            <th data-sort="CreatedOn">Created On</th>
                            <th data-sort="EditedBy">Edited By</th>
                            <th data-sort="EditedOn">Edited On</th>
                            <th data-sort="isActive">isActive</th>
                        </tr>
                        <tr class="bg-light text-dark">
                            <th></th><th></th>
                            <th><input class="form-control form-control-sm column-search" data-field="designationcode" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="designationName" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="probation" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="insCatergory" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="insamount" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="createdBy" /></th>
                            <th></th>
                            <th><input class="form-control form-control-sm column-search" data-field="editedBy" /></th>
                            <th></th>
                            <th><input class="form-control form-control-sm column-search" data-field="isActive" /></th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
            <div class="d-flex justify-content-between align-items-center">
                <span id="recordInfo"></span>
                <div>
                    <button class="btn btn-outline-secondary btn-sm" id="btnPrev">Prev</button>
                    <span id="pageInfo" class="mx-2"></span>
                    <button class="btn btn-outline-secondary btn-sm" id="btnNext">Next</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="designationModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="designationModalTitle">Add Designation</h5>
                <button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <form id="designationForm">
                    <input type="hidden" id="sno" name="Sno" value="0" />
                    <div class="row">
                        <div class="col-md-6 form-group"><label>Designation Name</label><input class="form-control" id="designationName" name="designationName" required maxlength="150" /></div>
                        <div class="col-md-6 form-group"><label>Designation Code</label><input class="form-control" id="designationcode" name="designationcode" required maxlength="50" /></div>
                        <div class="col-md-6 form-group"><label>Insurance Category Search</label><input class="form-control" id="insuranceCategorySearch" placeholder="Search A/B/C/D" /></div>
                        <div class="col-md-6 form-group"><label>Insurance Category</label><select class="form-control" id="insCatergory" name="insCatergory" required></select></div>
                        <div class="col-md-6 form-group"><label>Probation Search</label><input class="form-control" id="probationSearch" placeholder="Search 0/3/4/6" /></div>
                        <div class="col-md-6 form-group"><label>Probation</label><select class="form-control" id="probation" name="probation" required></select></div>
                        <div class="col-md-6 form-group"><label>Insurance Amount</label><input type="number" step="0.01" min="0" class="form-control" id="insamount" name="insamount" required /></div>
                    </div>
                </form>
                <div class="alert d-none" id="formMessage"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Exit</button>
                <button type="button" class="btn btn-primary" onclick="saveDesignation()">Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteDesignationModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white"><h5 class="modal-title">Confirm Delete</h5><button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button></div>
            <div class="modal-body">Are you sure you want to delete this designation?</div>
            <div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button><button type="button" class="btn btn-danger" id="btnConfirmDesignationDelete">Delete</button></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/master/jsDesignation.js"></script>
}
