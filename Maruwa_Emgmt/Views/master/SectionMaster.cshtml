@{
    ViewData["Title"] = "Section Master";
}

<div class="container-fluid mt-3">
    @Html.AntiForgeryToken()
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <span>Section Master</span>
            <button type="button" class="btn btn-light btn-sm" onclick="openSectionModal()"><i class="bi bi-plus-circle"></i> Add Section</button>
        </div>
        <div class="card-body">
            <div class="row mb-2 align-items-center">
                <div class="col-md-2">
                    <select id="pageSizeSelect" class="form-control form-control-sm">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <input type="text" id="globalSearch" class="form-control form-control-sm" placeholder="Global search across all columns" />
                </div>
                <div class="col-md-3">
                    <input type="text" id="departmentManualSearch" class="form-control form-control-sm" placeholder="Search department manually by code/name" />
                </div>
                <div class="col-md-3 text-right">
                    <button class="btn btn-success btn-sm" onclick="exportSection('xlsx')">Excel</button>
                    <button class="btn btn-info btn-sm" onclick="exportSection('csv')">CSV</button>
                    <button class="btn btn-danger btn-sm" onclick="exportSection('pdf')">PDF</button>
                    <button class="btn btn-secondary btn-sm" onclick="window.print()">Print</button>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-sm" id="tblSection" style="font-size:13px;">
                    <thead class="bg-secondary text-white">
                        <tr>
                            <th>Edit</th>
                            <th>Delete</th>
                            <th data-sort="SectionCode">SectionCode</th>
                            <th data-sort="Sectionname">Sectionname</th>
                            <th data-sort="SectionId">SectionId</th>
                            <th data-sort="Departmentcode">Departmentcode</th>
                            <th data-sort="SubDepartmentName">SubDepartmentName</th>
                            <th data-sort="issectionActive">issectionActive</th>
                            <th data-sort="CreatedBy">Created By</th>
                            <th data-sort="CreatedOn">Created On</th>
                            <th data-sort="EditedBy">Edited By</th>
                            <th data-sort="EditedOn">Edited On</th>
                        </tr>
                        <tr class="bg-light text-dark">
                            <th></th><th></th>
                            <th><input class="form-control form-control-sm column-search" data-field="sectionCode" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="sectionname" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="sectionId" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="departmentcode" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="subDepartmentName" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="issectionActive" /></th>
                            <th><input class="form-control form-control-sm column-search" data-field="createdBy" /></th>
                            <th></th>
                            <th><input class="form-control form-control-sm column-search" data-field="editedBy" /></th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
            <div class="d-flex justify-content-between align-items-center">
                <span id="recordInfo"></span>
                <div>
                    <button class="btn btn-outline-secondary btn-sm" id="btnPrev">Prev</button>
                    <span id="pageInfo" class="mx-2"></span>
                    <button class="btn btn-outline-secondary btn-sm" id="btnNext">Next</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="sectionModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="sectionModalTitle">Add Section</h5>
                <button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <form id="sectionForm">
                    <input type="hidden" id="sectionId" name="SectionId" value="0" />
                    <div class="row">
                        <div class="col-md-6 form-group"><label>Section Code</label><input class="form-control" id="sectionCode" name="SectionCode" required maxlength="20" /></div>
                        <div class="col-md-6 form-group"><label>Section Name</label><input class="form-control" id="sectionname" name="Sectionname" required maxlength="150" /></div>
                        <div class="col-md-6 form-group">
                            <label>Department Code</label>
                            <select class="form-control" id="departmentcode" name="Departmentcode" required></select>
                            <small class="form-text text-muted">Type in department search to filter by code/name.</small>
                        </div>
                        <div class="col-md-6 form-group"><label>Sub Department Name</label><input class="form-control" id="subDepartmentName" name="SubDepartmentName" required maxlength="150" /></div>
                    </div>
                </form>
                <div class="alert d-none" id="formMessage"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Exit</button>
                <button type="button" class="btn btn-primary" onclick="saveSection()">Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteSectionModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white"><h5 class="modal-title">Confirm Delete</h5><button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button></div>
            <div class="modal-body">Are you sure you want to delete this section?</div>
            <div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button><button type="button" class="btn btn-danger" id="btnConfirmSectionDelete">Delete</button></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/master/jsSectionMaster.js"></script>
}
